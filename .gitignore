# ==============================================
# 【强制放行】VS2026 核心项目文件（必须保留）
# ==============================================
# VS2026 新版解决方案文件（.slnx）
!*.slnx
# VS 项目配置文件（.vcxproj）
!*.vcxproj
# VS 筛选器文件（控制VS内文件目录结构）
!*.vcxproj.filters

# ==============================================
# VS 缓存与索引文件（全部忽略）
# ==============================================
# VS 缓存主目录（包含浏览数据库、调试状态等）
.vs/
# 预编译头缓存目录
ipch/
# 本地历史记录目录
.localhistory/
# 远程机器缓存目录
.RemoteMachineCache/

# ==============================================
# 重点屏蔽：VS2026 浏览数据库（.db文件）
# ==============================================
# Browse.VC.db 及相关日志文件
*.db
*.db-shm
*.db-wal
# VS 索引文件
*.vsidx
# SQLite 数据库文件
*.sqlite
*.sqlite-shm
*.sqlite-wal

# ==============================================
# 编译输出目录（全部忽略）
# ==============================================
# 平台架构目录
x64/
x86/
ARM/
ARM64/
# 配置目录
Debug/
Release/
# 其他配置目录
ARM64/Debug/
ARM64/Release/

# ==============================================
# 编译中间文件与产物（全部忽略）
# ==============================================
# 目标文件
*.obj
*.iobj
*.o
*.a
*.lib
*.exp
*.dll
*.exe
*.out
*.app
*.so
*.dylib
*.pdb
*.ipdb
*.ilk
*.map
*.manifest
*.res
*.pch
*.gch
*.tlog
*.lastbuildstate
*.recipe
*.log
*.vspx
*.idb
*.su
*.tlh
*.tli

# ==============================================
# 用户个人配置文件（全部忽略）
# ==============================================
# 本地用户配置（包含个人调试设置、本地路径）
*.user
*.suo
*.wsuo
# VS 窗口布局文件
*.vsstate
# 团队资源文件
*.vspscc
*.vssscc

# ==============================================
# 其他临时与系统文件（全部忽略）
# ==============================================
*.tmp
*.bak
*.swp
*.swo
*~
Thumbs.db
.DS_Store
desktop.ini